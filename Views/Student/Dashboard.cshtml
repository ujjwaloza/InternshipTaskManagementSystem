@{
    ViewData["Title"] = "Student Dashboard";
}

@* <h2 class="fw-bold text-dark mb-4">
    <i class="fa-solid fa-users"></i> Student Dashboard
</h2> *@



<div class="row g-4">

    <div class="col-md-4">
        <div class="card shadow  dashboard-card">
            <div class="card-body text-center">
                <i class="bi bi-list-task fs-1 text-primary"></i>
                <h5 class="mt-3 fw-semibold">My Tasks</h5>
                <p class="text-muted small">
                    View and update assigned tasks
                </p>
                <a asp-controller="Student"
                   asp-action="ViewTasks"
                   class="btn btn-primary w-100">
                    View Tasks
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow  dashboard-card">
            <div class="card-body text-center">
                <i class="bi bi-journal-text fs-1 text-success"></i>
                <h5 class="mt-3 fw-semibold">Weekly Report</h5>
                <p class="text-muted small">
                    Submit your weekly progress report
                </p>
                <a asp-action="SubmitReport"
                   class="btn btn-success w-100">
                    Submit Report
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow  dashboard-card">
            <div class="card-body text-center">
                <i class="bi bi-chat-left-text fs-1 text-warning"></i>
                <h5 class="mt-3 fw-semibold">Mentor Feedback</h5>
                <p class="text-muted small">
                    View mentor comments & feedback
                </p>
                <a asp-action="MyReports"
                   class="btn btn-warning w-100">
                    View Feedback
                </a>
            </div>
        </div>
    </div>

</div>





@section style{
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

@model IEnumerable<InternshipTaskManagementSystem.Models.TaskModel>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">My Tasks</h3>
        <span class="badge bg-primary fs-6">
            Total Tasks: @Model.Count()
        </span>
    </div>

    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Assigned Tasks</h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover table-bordered align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Task Title</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var task in Model)
                    {
                        <tr>
                            <td class="fw-semibold" style="word-break:break-all;">@task.Title</td>
                            <td style="max-width:300px; word-break: break-all;">
                                @task.Description
                            </td>
                            <td>
                                @{
                                    var status = (task.Status ?? "").Trim();
                                }

                                @if (status == "Pending")
                                {
                                    <span class="badge bg-secondary">Pending</span>
                                }
                                else if (status == "In Progress")
                                {
                                    <span class="badge bg-warning text-dark">In Progress</span>
                                }
                                else if (status == "Completed")
                                {
                                    <span class="badge bg-success">
                                        <i class="fa-solid fa-check-double"></i> Completed
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Unknown (@status)</span>
                                }
                            </td>

                            <td class="text-center">
                                @if (status == "Pending")
                                {
                                    <a asp-action="StartTask"
                                       asp-route-id="@task.TaskId"
                                       class="btn btn-primary btn-sm">
                                        Start
                                    </a>
                                }
                                else if (status == "In Progress")
                                {
                                    <a asp-action="CompleteTask"
                                       asp-route-id="@task.TaskId"
                                       class="btn btn-success btn-sm">
                                       
                                         Complete
                                    </a>
                                }
                                else if (status == "Completed")
                                {
                                    <span class="badge bg-success px-3 py-2">Completed</span>
                                }
                            </td>


                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

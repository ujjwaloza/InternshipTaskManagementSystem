@model IEnumerable<InternshipTaskManagementSystem.Models.TaskModel>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">My Tasks</h3>
        <span class="badge bg-primary fs-6">
            Total Tasks: @Model.Count()
        </span>
    </div>

    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Assigned Tasks</h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Task Title</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var task in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@task.Title</td>
                            <td>
                                @if (task.Status == "ToDo")
                                {
                                    <span class="badge bg-secondary">To Do</span>
                                }
                                else if (task.Status == "InProgress")
                                {
                                    <span class="badge bg-warning">In Progress</span>
                                }
                                else if (task.Status == "Completed")
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Unknown</span>
                                }

                            </td>

                            <td class="text-center">
                                @switch (task.Status)
                                {
                                    case "To Do":
                                        <a asp-controller="Student"
                                           asp-action="StartTask"
                                           asp-route-id="@task.TaskId"
                                           class="btn btn-primary btn-sm">
                                            ▶ Start
                                        </a>
                                        break;

                                    case "In Progress":
                                        <a asp-controller="Student"
                                           asp-action="CompleteTask"
                                           asp-route-id="@task.TaskId"
                                           class="btn btn-success btn-sm">
                                            ✔ Complete
                                        </a>
                                        break;

                                    case "Completed":
                                        <span class="badge bg-success px-3 py-2">Completed</span>
                                        break;

                                    default:
                                        <span class="badge bg-danger">Unknown</span>
                                        break;
                                }
                            </td>


                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

    <nav class="navbar navbar-dark bg-light-subtle px-3 border border-bottom sticky-top ">
        <div class="container-fluid d-flex align-items-center">

            <div class="d-flex text-dark align-items-center">
                
           <i class="fa-solid fa-chart-bar"></i>
                <p class="navbar-brand text-dark fw-bold mb-0 ms-auto" href="">
                    TaskManagement
                </p>
               

               
                @{
                    var role = Context.Session.GetString("UserRole");
                }

                @if (!string.IsNullOrEmpty(role))
                {
                    if (role == "Admin")
                    {
                        <a class="nav-link text-dark fw-semibold ms-3 d-none d-lg-block"
                           href="/Admin/Dashboard">Home</a>

                        <a class="nav-link text-dark fw-semibold ms-3 d-none d-lg-block"
                           href="">Privacy</a>

                       
                    }
                    else if (role == "Mentor")
                    {
                        <a class="nav-link text-dark fw-semibold ms-3 d-none d-lg-block"
                           href="/Mentor/Dashboard">Home</a>

                        <a class="nav-link text-dark fw-semibold ms-3 d-none d-lg-block"
                           href="">Privacy</a>
                    }
                    else if (role == "Student")
                    {
                        <a class="nav-link text-dark fw-semibold ms-3 d-none d-lg-block"
                           href="/Student/Dashboard">Home</a>

                        <a class="nav-link text-dark fw-semibold ms-3 d-none d-lg-block"
                           href="">Privacy</a>
                    }
                }

            </div>
             <button class="navbar-toggler ms-auto bg-black mt-3 d-lg-none border border-dark rounded"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#mobileMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

            <div class="d-none d-lg-flex align-items-center ms-auto">
             
                <span class="text-dark text-bold mt-1 me-2">
                       <i class="fa-solid fa-user-check"></i>
                    @Context.Session.GetString("UserName")
                </span>

                <a class="text-dark text-decoration-none " href="/Account/Logout">
                    <i class="fa-solid fa-arrow-right-from-bracket mt-2"></i>
                    Logout
                </a>

            </div>

        </div>

        <!-- MOBILE MENU -->
        <div class="offcanvas offcanvas-end text-bg-light w-50 h-50 border border-dark rounded border-2 border-end-0" tabindex="-1" id="mobileMenu">

            <div class="offcanvas-header">
                <h5 class="offcanvas-title">Menu</h5>
                <button type="button" class="btn-close btn-close-dark" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="offcanvas-body">
                <ul class="navbar-nav ">

                    @if (!string.IsNullOrEmpty(role))
                    {
                        if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-black ms-3" href="/Admin/Dashboard">Home</a>
                            </li>
                        }
                        else if (role == "Mentor")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-black ms-3" href="/Mentor/Dashboard">Home</a>
                            </li>
                        }
                        else if (role == "Student")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-black ms-3" href="/Student/Dashboard">Home</a>
                            </li>
                        }
                    }


                    <li class="nav-item">
                        <span class="nav-link text-black">
                            👤 @Context.Session.GetString("UserName")
                        </span>
                    </li>

                    <li class="nav-item">
                        <a class="btn text-black w-50 ms-1" href="/Account/Logout">
                            Logout
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>



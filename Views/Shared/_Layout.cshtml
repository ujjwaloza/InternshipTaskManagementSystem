<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InternshipTaskManagementSystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InternshipTaskManagementSystem.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

</head>
<body>
    @* <nav class="navbar navbar-expand-lg
    @(Context.Session.GetString("UserRole") == "Admin" ? "bg-danger" :
               Context.Session.GetString("UserRole") == "Mentor" ? "bg-primary" :
               "bg-success")
    navbar-dark"> *@

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">InternshipTaskManagement</a> 
            

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">

                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Dashboard">
                                 Home
                            </a>
                        </li>
                    }

                    @if (Context.Session.GetString("UserRole") == "Mentor")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Mentor/Dashboard">
                                Home
                            </a>
                        </li>
                    }

                    @if (Context.Session.GetString("UserRole") == "Student")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Student/Dashboard">
                                  Home
                            </a>
                        </li>
                    }

                    @* <li class="nav-item">
                        <a class="nav-link text-danger" href="/Account/Logout">
                            Logout
                        </a>
                    </li> *@

                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)
</body>

</html>

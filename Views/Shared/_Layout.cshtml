<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InternshipTaskManagementSystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InternshipTaskManagementSystem.styles.css" asp-append-version="true" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    @RenderSection("style", required: false)
</head>

<body>

    <!-- 🔥 NAVBAR -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">

            <!-- LEFT SIDE -->
            <div class="d-flex align-items-center">

                <!-- Logo -->
                <a class="navbar-brand fw-bold mb-0 me-3" href="">
                    InternshipTaskManagement
                </a>

                <!-- ✅ HOME (DESKTOP ONLY) -->
                @{
                    var role = Context.Session.GetString("UserRole");
                }

                @if (!string.IsNullOrEmpty(role))
                {
                    if (role == "Admin")
                    {
                        <a class="nav-link text-white fw-semibold d-none d-lg-block"
                           href="/Admin/Dashboard">Home</a>
                    }
                    else if (role == "Mentor")
                    {
                        <a class="nav-link text-white fw-semibold d-none d-lg-block"
                           href="/Mentor/Dashboard">Home</a>
                    }
                    else if (role == "Student")
                    {
                        <a class="nav-link text-white fw-semibold d-none d-lg-block"
                           href="/Student/Dashboard">Home</a>
                    }
                }

            </div>

            <!-- ✅ HAMBURGER BUTTON (MOBILE ONLY) -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#mobileMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- 🔥 OFFCANVAS MENU -->
            <div class="offcanvas offcanvas-top text-bg-dark" tabindex="-1" id="mobileMenu">

                <!-- Header -->
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title">Menu</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
                </div>

                <!-- Body -->
                <div class="offcanvas-body">

                    <ul class="navbar-nav">

                        <!-- HOME (MOBILE ONLY) -->
                        @if (!string.IsNullOrEmpty(role))
                        {
                            if (role == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Admin/Dashboard">Home</a>
                                </li>
                            }
                            else if (role == "Mentor")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Mentor/Dashboard">Home</a>
                                </li>
                            }
                            else if (role == "Student")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Student/Dashboard">Home</a>
                                </li>
                            }
                        }

                        <hr class="text-white" />

                        <!-- USER -->
                        <li class="nav-item">
                            <span class="nav-link">
                                👤 @Context.Session.GetString("UserName")
                            </span>
                        </li>

                        <!-- LOGOUT -->
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="/Account/Logout">
                                Logout
                            </a>
                        </li>

                    </ul>

                </div>
            </div>

        </div>
    </nav>

    <!-- 🔥 PAGE CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
@model IEnumerable<dynamic>

<div class="container mt-4">

    <h3 class="fw-bold mb-4">📄 Weekly Reports</h3>

    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Student</th>
                <th>Week</th>
                <th>Report</th>
                <th>Submitted On</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.WeekNumber</td>
                    <td>@item.Content</td>
                    <td>@Convert.ToDateTime(item.SubmittedOn).ToString("dd MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>

</div>
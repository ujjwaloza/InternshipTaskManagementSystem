@{
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
    /* BODY */
    body {
        background: #f8fafc;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
        padding: 16px;
    }

    /* CONTAINER */
    .login-container {
        width: 100%;
        max-width: 400px;
    }

    /* TITLE */
    .login-title {
        font-size: 28px;
        font-weight: 600;
        text-align: center;
    }

    .login-subtitle {
        text-align: center;
        color: #6b7280;
        margin-bottom: 20px;
        font-size: 14px;
    }

    /* LABEL */
    .login .form-label {
        font-weight: 500;
        margin-bottom: 5px;
    }

    /* INPUT */
    .login .form-control {
        height: 45px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        padding-right: 40px; /*  space for eye icon */
    }

        .login .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 2px #e0e7ff;
        }

    /* PASSWORD WRAPPER */
    .password-wrapper {
        position: relative;
    }

        /* FIXED ICON POSITION */
        .password-wrapper i {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%); /*  vertical center fix */
            color: #9ca3af;
            cursor: pointer;
            font-size: 18px;
        }

    /* REMEMBER + FORGOT */
    .extra-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 12px 0;
        font-size: 14px;
    }

        .extra-row a {
            text-decoration: none;
            color: #6366f1;
        }

    /* LOGIN BUTTON */
    .btn-login {
        width: 100%;
        height: 45px;
        background: #4f46e5;
        color: white;
        border-radius: 8px;
        border: none;
        font-weight: 500;
    }

        .btn-login:hover {
            background: #4338ca;
        }
form{
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 24px;
    border: 2px solid black;
		background: white;
		border-radius: 12px;
}
    
</style>

<div class="login-container">

    <h2 class="login-title">Login</h2>
    <p class="login-subtitle">Hi, Welcome back 👋</p>
  

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger text-center">
            @ViewBag.Error
        </div>
    }

    <form asp-action="Login" method="post">

        <!-- EMAIL -->
        <div class="mb-3 login">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" placeholder="E.g. johndoe@email.com" required />
        </div>

        <!-- PASSWORD -->
        <div class="mb-3 password-wrapper login">
            <label class="form-label">Password</label>
            <input type="password" id="password" name="password" class="form-control" placeholder="Enter your password" required />
            <i class="bi bi-eye-slash mt-3" onclick="togglePassword()"></i>
        </div>

        <!-- REMEMBER + FORGOT -->
        <div class="extra-row">
            <div>
                <input type="checkbox"> Remember Me
            </div>
            <a href="#">Forgot Password?</a>
        </div>

        <!-- LOGIN BUTTON -->
        <button type="submit" class="btn-login">
            Login
        </button>
    </form>

   

</div>

<script>
    function togglePassword() {
        const input = document.getElementById("password");
        const icon = document.querySelector(".password-wrapper i");

        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        } else {
            input.type = "password";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        }
    }
</script>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
   

    @* <h2 class="fw-bold mb-4">
        <i class="fa-brands fa-black-tie"></i>
         Admin Dashboard
    </h2> *@

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow dashboard-card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill fs-1 text-primary"></i>
                    <h5 class="mt-3 fw-semibold">Manage Users</h5>
                    <p class="text-muted small">Add, edit and remove users</p>
                    <a asp-action="Users" class="btn btn-primary w-100">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow dashboard-card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-kanban fs-1 text-success"></i>
                    <h5 class="mt-3 fw-semibold">Manage Projects</h5>
                    <p class="text-muted small">Create and assign projects</p>
                    <a asp-action="Projects" class="btn btn-success w-100">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow dashboard-card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-file-earmark-text fs-1 text-warning"></i>
                    <h5 class="mt-3 fw-semibold">Weekly Reports</h5>
                    <p class="text-muted small">Monitor student progress</p>
                    <a asp-action="WeeklyReports" class="btn btn-warning w-100">
                        View Weekly Reports
                    </a>
                </div>
            </div>
        </div>

    </div>

    

</div>

@section style{
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

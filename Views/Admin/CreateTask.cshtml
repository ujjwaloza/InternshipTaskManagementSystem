@model InternshipTaskManagementSystem.Models.TaskModel

@{
    ViewData["Title"] = "Create Task";
}

<h2>Create Task</h2>

<form asp-action="CreateTask" method="post">

    <div class="form-group">
        <label>Task Title</label>
        <input asp-for="Title" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Project</label>
        <select asp-for="ProjectId" class="form-control" required>
            <option value="">-- Select Project --</option>
            @foreach (var p in ViewBag.Projects)
            {
                <option value="@p.ProjectId">
                    @p.Title (Student: @p.Student.FullName)
                </option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Create Task</button>

</form>

